# Copy to terraform.tfvars and fill in. NEVER commit terraform.tfvars.

okta_org_name  = "dev-123456"
okta_base_url  = "okta.com"
okta_client_id = "0oa..."
# Prefer env var: export TF_VAR_okta_private_key="$(cat terraform-app.pem)"
okta_private_key = <<-EOT
-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----
EOT

app_name         = "Acme Storefront"
environment      = "dev"
web_app_base_url = "http://localhost:3000"
spa_base_url     = "http://localhost:5173"
api_audience     = "api://acme-storefront"

api_scopes = {
  "orders:read"  = "Read orders"
  "orders:write" = "Create and modify orders"
}

# Only needed if provisioning the M2M service integration:
# service_public_key_modulus = "base64url-modulus..."
